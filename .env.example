# Opaux Environment Variables
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-32
FLASK_ENV=production
SCHEDULER_ENABLED=1

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Recommended: Postmark (smtp.postmarkapp.com:587)
# Alternative: Gmail, AWS SES, Mailgun
MAIL_SERVER=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-postmark-api-token
MAIL_PASSWORD=your-postmark-api-token
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@yourdomain.com

# ── Redis (optional — for multi-worker rate limiting) ────────────────────────
# REDIS_URL=redis://localhost:6379/0

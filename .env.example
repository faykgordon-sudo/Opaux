# ── Opaux Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env && nano .env

# ── Required ──────────────────────────────────────────────────────────────────

# Flask secret key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Application ───────────────────────────────────────────────────────────────

FLASK_ENV=production

# Admin email(s) — comma-separated, these accounts get admin access
ADMIN_EMAILS=you@example.com

# Enable background scheduler (discovers/scores jobs on a schedule)
SCHEDULER_ENABLED=0

# ── Email (Postmark recommended — leave blank to disable) ─────────────────────

MAIL_SERVER=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@opaux.com

# ── Stripe (leave blank to disable payments) ──────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ── CLI overrides (optional) ──────────────────────────────────────────────────

# OPAUX_FORMAT=american        # american | german | europass
# OPAUX_LANG=en                # en | de | fr | es | ...
# OPAUX_DB=data/jobs.db
# OPAUX_PROFILE=config/profile.yaml
